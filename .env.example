# Contact form API endpoint
# The blog's contact form POSTs to: ${PUBLIC_CONTACT_API_URL}/v1/contact
#
# If you don't have a backend API, leave this blank — the form will silently
# succeed (honeypot mode) so the page still renders without errors.
#
# For local development:
PUBLIC_CONTACT_API_URL=http://localhost:5000
#
# For production (replace with your own API URL):
# PUBLIC_CONTACT_API_URL=https://your-api.example.com

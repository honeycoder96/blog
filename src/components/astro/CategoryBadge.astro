---
import { CATEGORY_COLOR_MAP } from '../../config/categories';

interface Props {
  category: string;
  class?: string;
}

const { category, class: className = '' } = Astro.props;

const colors = CATEGORY_COLOR_MAP[category] ?? 'border-line-strong text-fg-muted';
---

<span
  class={`px-3 py-1 rounded-full border text-xs font-mono uppercase tracking-wider ${colors} ${className}`}
>
  {category}
</span>

---
import { siteConfig } from '../../config/site';

const year = new Date().getFullYear();
const links = [
  ...(siteConfig.social.github ? [{ label: 'Github', href: siteConfig.social.github }] : []),
  ...(siteConfig.social.linkedin ? [{ label: 'LinkedIn', href: siteConfig.social.linkedin }] : []),
  ...(siteConfig.social.email ? [{ label: 'Email', href: `mailto:${siteConfig.social.email}` }] : []),
];
---

<footer class="border-t border-line-faint px-8 lg:px-24 py-12 mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div>
      <a href="/" class="font-display font-bold text-xl tracking-tight text-fg">
        {siteConfig.siteName}
      </a>
      <p class="text-fg-faint text-sm mt-1 font-mono">
        &copy; {year} — Writing about the craft
      </p>
    </div>

    <div class="flex gap-8">
      {links.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden inline-flex h-5 font-mono text-sm tracking-widest uppercase text-fg-muted hover:text-fg transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>

---
type Status = 'full' | 'partial' | 'flag' | 'none';
type Browser = 'chrome' | 'firefox' | 'safari' | 'edge' | 'node';

interface BrowserEntry {
  browser: Browser;
  version?: string;
  status: Status;
  note?: string;
}

interface Props {
  feature: string;
  data: BrowserEntry[];
}

const { feature, data } = Astro.props;

const browserMeta: Record<Browser, { name: string; icon: string }> = {
  chrome: {
    name: 'Chrome',
    icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/>',
  },
  firefox: {
    name: 'Firefox',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/>',
  },
  safari: {
    name: 'Safari',
    icon: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  },
  edge: {
    name: 'Edge',
    icon: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6z"/>',
  },
  node: {
    name: 'Node.js',
    icon: '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  },
};

const statusMeta: Record<Status, { symbol: string; label: string; cls: string }> = {
  full:    { symbol: '✓', label: 'Full support',    cls: 'bs-full' },
  partial: { symbol: '~', label: 'Partial support', cls: 'bs-partial' },
  flag:    { symbol: '⚑', label: 'Behind a flag',   cls: 'bs-flag' },
  none:    { symbol: '✗', label: 'Not supported',   cls: 'bs-none' },
};
---

<div class="bs-block">
  <div class="bs-header">{feature}</div>
  <div class="bs-grid">
    {data.map((entry) => {
      const bm = browserMeta[entry.browser];
      const sm = statusMeta[entry.status];
      return (
        <div class="bs-cell">
          <svg
            class="bs-browser-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-label={bm.name}
          >
            <Fragment set:html={bm.icon} />
          </svg>
          <div class="bs-browser-name">{bm.name}</div>
          <div class:list={['bs-status', sm.cls]} title={sm.label}>
            {sm.symbol}
          </div>
          {entry.version && entry.status !== 'none' && (
            <div class="bs-version">v{entry.version}+</div>
          )}
          {entry.note && <div class="bs-note">{entry.note}</div>}
        </div>
      );
    })}
  </div>
  <div class="bs-legend">
    <span><span class="bs-full">✓</span> Full</span>
    <span><span class="bs-partial">~</span> Partial</span>
    <span><span class="bs-flag">⚑</span> Flag</span>
    <span><span class="bs-none">✗</span> None</span>
  </div>
</div>

<style>
  .bs-block {
    margin: 2rem 0;
    border: 1px solid var(--theme-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .bs-header {
    padding: 0.625rem 1.25rem;
    background: var(--theme-bg-raised);
    border-bottom: 1px solid var(--theme-line);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--theme-fg-faint);
  }

  .bs-grid {
    display: flex;
    justify-content: center;
    gap: 0;
    padding: 1.5rem;
    background: var(--theme-bg-inset);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .bs-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    min-width: 5rem;
    text-align: center;
  }

  .bs-browser-icon {
    color: var(--theme-fg-muted);
  }

  .bs-browser-name {
    font-size: 0.75rem;
    color: var(--theme-fg-muted);
    font-weight: 500;
  }

  .bs-status {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
  }

  .bs-full    { color: #22c55e; }
  .bs-partial { color: #f59e0b; }
  .bs-flag    { color: #6366f1; }
  .bs-none    { color: var(--theme-fg-ghost); }

  .bs-version {
    font-size: 0.7rem;
    color: var(--theme-fg-faint);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .bs-note {
    font-size: 0.7rem;
    color: var(--theme-fg-faint);
    line-height: 1.4;
  }

  .bs-legend {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    padding: 0.625rem;
    border-top: 1px solid var(--theme-line);
    font-size: 0.7rem;
    color: var(--theme-fg-faint);
    background: var(--theme-bg-raised);
  }

  .bs-legend span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
</style>

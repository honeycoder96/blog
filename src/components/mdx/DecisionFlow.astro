---
type NodeType = 'start' | 'end' | 'decision' | 'action' | 'result';

interface FlowNode {
  id: string;
  type: NodeType;
  label: string;
  sublabel?: string;
}

interface FlowEdge {
  from: string;
  to: string;
  label?: string;
  style?: 'solid' | 'dashed';
}

interface Props {
  nodes: FlowNode[];
  edges: FlowEdge[];
  title?: string;
  caption?: string;
}

const { nodes, edges, title, caption } = Astro.props;

const uid = `df-${Math.random().toString(36).slice(2, 7)}`;

// ── Layout constants ────────────────────────────────────────────────────────
const W          = 780;
const COL_0_X    = 240;  // x-centre of primary column
const COL_1_X    = 570;  // x-centre of branch column
const ROW_H      = 96;   // vertical distance between row centres
const TOP_PAD    = 24;
const BOT_PAD    = 36;

// Node shape half-sizes
const RECT_W = 170; const RECT_H = 40; const RECT_RX = 7;
const DIA_H  = 30;  // diamond half-height (tip to centre)
const DIA_W  = 88;  // diamond half-width
const CIRC_R = 18;

// ── BFS layout ─────────────────────────────────────────────────────────────
const rowOf = new Map<string, number>();
const colOf = new Map<string, number>();

const startNode = nodes.find(n => n.type === 'start') ?? nodes[0];
const queue: Array<{ id: string; row: number; col: number }> = [
  { id: startNode.id, row: 0, col: 0 },
];
const seen = new Set<string>();

while (queue.length > 0) {
  const item = queue.shift()!;
  if (seen.has(item.id)) continue;
  seen.add(item.id);
  rowOf.set(item.id, item.row);
  colOf.set(item.id, item.col);

  const out = edges.filter(e => e.from === item.id);
  out.forEach((edge, i) => {
    if (!seen.has(edge.to) && !queue.some(q => q.id === edge.to)) {
      queue.push({ id: edge.to, row: item.row + 1, col: item.col + i });
    }
  });
}

// Determine if two-column layout is needed
const maxCol = Math.max(0, ...Array.from(colOf.values()));
const singleCol = maxCol === 0;

function nodeX(id: string): number {
  const col = colOf.get(id) ?? 0;
  if (singleCol) return W / 2;
  return col === 0 ? COL_0_X : COL_1_X;
}

function nodeY(id: string): number {
  return TOP_PAD + (rowOf.get(id) ?? 0) * ROW_H + ROW_H / 2;
}

// Bottom / top / left / right connection points
function bottom(id: string): [number, number] {
  const t = nodes.find(n => n.id === id)!.type;
  const x = nodeX(id); const y = nodeY(id);
  if (t === 'start' || t === 'end') return [x, y + CIRC_R];
  if (t === 'decision') return [x, y + DIA_H];
  return [x, y + RECT_H / 2];
}
function top(id: string): [number, number] {
  const t = nodes.find(n => n.id === id)!.type;
  const x = nodeX(id); const y = nodeY(id);
  if (t === 'start' || t === 'end') return [x, y - CIRC_R];
  if (t === 'decision') return [x, y - DIA_H];
  return [x, y - RECT_H / 2];
}
function right(id: string): [number, number] {
  const t = nodes.find(n => n.id === id)!.type;
  const x = nodeX(id); const y = nodeY(id);
  if (t === 'start' || t === 'end') return [x + CIRC_R, y];
  if (t === 'decision') return [x + DIA_W, y];
  return [x + RECT_W / 2, y];
}

// Compute SVG height
const maxRow = Math.max(0, ...Array.from(rowOf.values()));
const SVG_H = TOP_PAD + (maxRow + 1) * ROW_H + BOT_PAD;

// ── Edge path builder ───────────────────────────────────────────────────────
function edgePath(edge: FlowEdge): string {
  const fromCol = colOf.get(edge.from) ?? 0;
  const toCol   = colOf.get(edge.to)   ?? 0;

  if (fromCol === toCol) {
    // Straight vertical: bottom of `from` to top of `to`
    const [x1, y1] = bottom(edge.from);
    const [x2, y2] = top(edge.to);
    return `M ${x1} ${y1} L ${x2} ${y2}`;
  }

  // Cross-column: exit from right side of `from`, travel horizontally, enter top of `to`
  const [rx, ry] = right(edge.from);
  const [tx, ty] = top(edge.to);
  const midY = (ry + ty) / 2;
  return `M ${rx} ${ry} L ${tx} ${ry} L ${tx} ${ty}`;
}

// ── Label midpoint ──────────────────────────────────────────────────────────
function edgeLabelPos(edge: FlowEdge): [number, number] {
  const fromCol = colOf.get(edge.from) ?? 0;
  const toCol   = colOf.get(edge.to)   ?? 0;
  if (fromCol === toCol) {
    const [x1, y1] = bottom(edge.from);
    const [, y2]   = top(edge.to);
    return [x1 + 8, (y1 + y2) / 2];
  }
  const [rx, ry] = right(edge.from);
  const [tx]     = top(edge.to);
  return [(rx + tx) / 2, ry - 8];
}

// ── Edge colours ────────────────────────────────────────────────────────────
const EDGE_YES = '#22c55e';
const EDGE_NO  = '#ef4444';
const EDGE_DEF = 'var(--theme-line-strong)';

function edgeColor(label?: string): string {
  if (!label) return EDGE_DEF;
  const l = label.toLowerCase();
  if (l === 'yes' || l === 'hit' || l === 'true' || l === 'valid') return EDGE_YES;
  if (l === 'no'  || l === 'miss'|| l === 'false'|| l === 'invalid') return EDGE_NO;
  return EDGE_DEF;
}
---

<div class="df-wrap">
  {title && <div class="df-header">{title}</div>}
  <div class="df-body">
    <svg
      viewBox={`0 0 ${W} ${SVG_H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="df-svg"
      role="img"
      aria-label={title ?? 'Decision flow diagram'}
    >
      <defs>
        <marker id={`${uid}-yes`} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <polygon points="0 0, 8 4, 0 8" fill={EDGE_YES} />
        </marker>
        <marker id={`${uid}-no`} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <polygon points="0 0, 8 4, 0 8" fill={EDGE_NO} />
        </marker>
        <marker id={`${uid}-def`} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <polygon points="0 0, 8 4, 0 8" fill="var(--theme-fg-ghost)" />
        </marker>
      </defs>

      {/* ── Edges (drawn first, behind nodes) ─────────────────────── */}
      {edges.map(edge => {
        const color = edgeColor(edge.label);
        const label = edge.label;
        const isYes = label?.toLowerCase() === 'yes' || label?.toLowerCase() === 'hit' || label?.toLowerCase() === 'true' || label?.toLowerCase() === 'valid';
        const isNo  = label?.toLowerCase() === 'no'  || label?.toLowerCase() === 'miss'|| label?.toLowerCase() === 'false'|| label?.toLowerCase() === 'invalid';
        const mId   = isYes ? `${uid}-yes` : isNo ? `${uid}-no` : `${uid}-def`;
        const dash  = edge.style === 'dashed' ? '5 3' : undefined;
        const [lx, ly] = edgeLabelPos(edge);

        return (
          <>
            <path
              d={edgePath(edge)}
              fill="none"
              stroke={color}
              stroke-width="1.75"
              stroke-dasharray={dash}
              marker-end={`url(#${mId})`}
            />
            {label && (
              <text
                x={lx} y={ly}
                class="df-edge-label"
                fill={color}
              >{label}</text>
            )}
          </>
        );
      })}

      {/* ── Nodes ─────────────────────────────────────────────────── */}
      {nodes.map(node => {
        const x = nodeX(node.id);
        const y = nodeY(node.id);

        if (node.type === 'start' || node.type === 'end') {
          return (
            <>
              {node.type === 'end' && (
                <circle cx={x} cy={y} r={CIRC_R + 5} class="df-end-ring" />
              )}
              <circle
                cx={x} cy={y} r={CIRC_R}
                class={node.type === 'start' ? 'df-start-circle' : 'df-end-circle'}
              />
              <text x={x} y={y} class="df-node-label df-circle-label" text-anchor="middle" dominant-baseline="middle">
                {node.label}
              </text>
            </>
          );
        }

        if (node.type === 'decision') {
          const pts = `${x},${y - DIA_H} ${x + DIA_W},${y} ${x},${y + DIA_H} ${x - DIA_W},${y}`;
          return (
            <>
              <polygon points={pts} class="df-decision" />
              <text x={x} y={node.sublabel ? y - 6 : y} class="df-node-label" text-anchor="middle" dominant-baseline="middle">
                {node.label}
              </text>
              {node.sublabel && (
                <text x={x} y={y + 10} class="df-node-sub" text-anchor="middle" dominant-baseline="middle">
                  {node.sublabel}
                </text>
              )}
            </>
          );
        }

        // action / result
        const bx = x - RECT_W / 2;
        const by = y - RECT_H / 2;
        return (
          <>
            <rect
              x={bx} y={by}
              width={RECT_W} height={RECT_H}
              rx={RECT_RX}
              class={node.type === 'result' ? 'df-result-rect' : 'df-action-rect'}
            />
            <text x={x} y={node.sublabel ? y - 6 : y} class="df-node-label" text-anchor="middle" dominant-baseline="middle">
              {node.label}
            </text>
            {node.sublabel && (
              <text x={x} y={y + 10} class="df-node-sub" text-anchor="middle" dominant-baseline="middle">
                {node.sublabel}
              </text>
            )}
          </>
        );
      })}
    </svg>
  </div>
  {caption && <div class="df-caption">{caption}</div>}
</div>

<style>
  .df-wrap {
    margin: 2rem 0;
    border: 1px solid var(--theme-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .df-header {
    padding: 0.625rem 1.25rem;
    background: var(--theme-bg-raised);
    border-bottom: 1px solid var(--theme-line);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--theme-fg-faint);
  }

  .df-body {
    background: var(--theme-bg-inset);
    overflow-x: auto;
    padding: 0.5rem;
  }

  .df-svg {
    display: block;
    width: 100%;
    height: auto;
    min-width: 320px;
  }

  /* Start node */
  .df-start-circle {
    fill: #6366f1;
    stroke: none;
  }

  /* End node */
  .df-end-circle {
    fill: #6366f1;
  }

  .df-end-ring {
    fill: none;
    stroke: #6366f1;
    stroke-width: 2;
  }

  /* Decision diamond */
  .df-decision {
    fill: rgba(245, 158, 11, 0.1);
    stroke: #f59e0b;
    stroke-width: 1.75;
  }

  /* Action rectangle */
  .df-action-rect {
    fill: var(--theme-bg-raised);
    stroke: var(--theme-line-strong);
    stroke-width: 1.5;
  }

  /* Result rectangle */
  .df-result-rect {
    fill: rgba(34, 197, 94, 0.08);
    stroke: rgba(34, 197, 94, 0.35);
    stroke-width: 1.5;
  }

  /* Text */
  .df-node-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    font-weight: 600;
    fill: var(--theme-fg-default);
  }

  .df-circle-label {
    fill: #ffffff;
    font-size: 11px;
  }

  .df-node-sub {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    fill: var(--theme-fg-faint);
  }

  .df-edge-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    font-weight: 600;
  }

  .df-caption {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    color: var(--theme-fg-faint);
    font-style: italic;
    text-align: center;
    border-top: 1px solid var(--theme-line);
    background: var(--theme-bg-raised);
  }
</style>

---
// ─── Types ────────────────────────────────────────────────────────────────────
type NodeType    = 'decision' | 'action' | 'terminal';
type NodeVariant = 'positive' | 'negative' | 'neutral' | 'warning';

interface FlowNode {
  /** Unique id — referenced by FlowEdge.from / to */
  id: string;
  /** Display text; long labels are word-wrapped automatically */
  label: string;
  /**
   * decision  = rounded rect + ◆ indicator (default) — use for questions
   * action    = rounded rect + coloured left bar     — use for intermediate steps
   * terminal  = pill shape                           — use for final recommendations
   */
  type?: NodeType;
  /**
   * Drives the accent colour on action / terminal nodes.
   * Has no visual effect on decision nodes.
   *   positive → green   negative → red
   *   neutral  → grey    warning  → amber
   */
  variant?: NodeVariant;
}

interface FlowEdge {
  from: string;
  to: string;
  /** "yes" → green  |  "no" → muted  |  anything else → default grey */
  label?: string;
}

interface Props {
  nodes: FlowNode[];
  edges: FlowEdge[];
  title?: string;
  caption?: string;
}

const { nodes, edges, title, caption } = Astro.props;

// ─── Layout constants ─────────────────────────────────────────────────────────
const NODE_W    = 160;   // node width (px)
const NODE_GAP  = 16;    // horizontal gap between adjacent sibling subtrees (px)
const LEVEL_GAP = 54;    // vertical gap: bottom of tallest node in parent level → top of child level (px)
const PAD_V     = 10;    // top / bottom padding inside every node (px)
const LINE_H    = 15;    // SVG line-height for wrapped text (px)
const SVG_PAD   = 24;    // outer canvas breathing room (px)
const CPL       = 20;    // approximate characters per wrapped line

// Horizontal text-start x-offset from node's left edge, per node type.
// Decision: clears the 10 px ◆ indicator + gap.
// Action:   clears the 3 px accent bar + gap.
// Terminal: centred (TX_TERMINAL is the centre x, not left offset).
const TX_DEC = 22;
const TX_ACT = 14;

// ─── Text wrapping ────────────────────────────────────────────────────────────
function wrap(text: string): string[] {
  const words = text.split(' ');
  const lines: string[] = [];
  let cur = '';
  for (const w of words) {
    if (!cur)                              { cur = w; continue; }
    if (cur.length + 1 + w.length <= CPL) { cur += ' ' + w;   }
    else                                  { lines.push(cur); cur = w; }
  }
  if (cur) lines.push(cur);
  return lines.length ? lines : [''];
}

const nodeLines = (n: FlowNode): string[] => wrap(n.label);
const nodeH     = (n: FlowNode): number   => PAD_V * 2 + nodeLines(n).length * LINE_H;

// ─── Build adjacency / parent maps ───────────────────────────────────────────
const kidsOf   = new Map<string, string[]>();
const parentOf = new Map<string, string>();

for (const n of nodes) kidsOf.set(n.id, []);
for (const e of edges) {
  kidsOf.get(e.from)?.push(e.to);
  parentOf.set(e.to, e.from);
}

// ─── Root: first node with no incoming edge ───────────────────────────────────
const rootId = (nodes.find(n => !parentOf.has(n.id)) ?? nodes[0])?.id;

// ─── BFS level assignment ─────────────────────────────────────────────────────
const lvlOf = new Map<string, number>();
if (rootId) {
  const q = [rootId];
  lvlOf.set(rootId, 0);
  while (q.length) {
    const id = q.shift()!;
    const l  = lvlOf.get(id)!;
    for (const c of kidsOf.get(id) ?? []) {
      if (!lvlOf.has(c)) { lvlOf.set(c, l + 1); q.push(c); }
    }
  }
}
const maxLvl = lvlOf.size ? Math.max(...lvlOf.values()) : 0;

// ─── Max node height at each level ────────────────────────────────────────────
// All siblings in a level share the same y-offset; we use the tallest node.
const maxHAt = new Array<number>(maxLvl + 1).fill(0);
for (const n of nodes) {
  const l = lvlOf.get(n.id) ?? 0;
  maxHAt[l] = Math.max(maxHAt[l], nodeH(n));
}

// ─── Cumulative Y offset per level ────────────────────────────────────────────
const yAt: number[] = [SVG_PAD];
for (let i = 1; i <= maxLvl; i++) yAt[i] = yAt[i - 1] + maxHAt[i - 1] + LEVEL_GAP;

// ─── Subtree widths (recursive) ───────────────────────────────────────────────
// A leaf occupies exactly NODE_W + NODE_GAP.
// An interior node occupies the sum of its children's subtree widths.
const subW = new Map<string, number>();
function csw(id: string): number {
  const ch = kidsOf.get(id) ?? [];
  const w  = ch.length ? ch.reduce((acc, c) => acc + csw(c), 0) : NODE_W + NODE_GAP;
  subW.set(id, w);
  return w;
}
if (rootId) csw(rootId);

// ─── Assign cx / y / h to every node ─────────────────────────────────────────
interface Pos { cx: number; y: number; h: number; lines: string[] }
const pmap = new Map<string, Pos>();

function assign(id: string, left: number): void {
  const sw   = subW.get(id) ?? NODE_W + NODE_GAP;
  const node = nodes.find(n => n.id === id)!;
  pmap.set(id, {
    cx:    left + sw / 2,
    y:     yAt[lvlOf.get(id) ?? 0],
    h:     nodeH(node),
    lines: nodeLines(node),
  });
  let cl = left;
  for (const c of kidsOf.get(id) ?? []) {
    assign(c, cl);
    cl += subW.get(c) ?? NODE_W + NODE_GAP;
  }
}
if (rootId) assign(rootId, SVG_PAD);

// ─── SVG canvas dimensions ────────────────────────────────────────────────────
const totalW = subW.get(rootId ?? '') ?? NODE_W + NODE_GAP;
const SVG_W  = totalW + SVG_PAD * 2;
const SVG_H  = pmap.size
  ? Math.max(...Array.from(pmap.values()).map(p => p.y + p.h)) + SVG_PAD
  : 100;

// ─── Colour helpers (variant-keyed) ──────────────────────────────────────────
//
// Terminal node fill / stroke are set via inline style="" — not SVG presentation
// attributes — because SVG presentation attributes don't expand CSS custom
// properties in all targeted browsers. Neutral falls back to a CSS class
// that can safely reference --theme-* vars.
//
type VMap = Record<NodeVariant, string | null>;

const TERM_FILL: VMap = {
  positive: 'rgba(34,197,94,0.11)',
  negative: 'rgba(239,68,68,0.11)',
  neutral:  null,                      // → .df-terminal-rect--neutral class
  warning:  'rgba(245,158,11,0.11)',
};
const TERM_STROKE: VMap = {
  positive: 'rgba(34,197,94,0.5)',
  negative: 'rgba(239,68,68,0.5)',
  neutral:  null,
  warning:  'rgba(245,158,11,0.5)',
};
const TERM_TEXT: VMap = {
  positive: '#4ade80',
  negative: '#f87171',
  neutral:  null,                      // inherits .df-node-text fill from CSS
  warning:  '#fbbf24',
};
const ACCENT: Record<NodeVariant, string> = {
  positive: '#22c55e',
  negative: '#ef4444',
  neutral:  '#6b7280',
  warning:  '#f59e0b',
};

// Edge stroke colour and weight
function eColor(label?: string): string {
  if (label === 'yes') return '#4ade80';
  if (label === 'no')  return 'rgba(156,163,175,0.75)';
  return 'rgba(156,163,175,0.55)';
}
function eWidth(label?: string): number { return label === 'yes' ? 2 : 1.5; }
---

<div class="df-wrap">
  {title && <div class="df-header">{title}</div>}

  <div class="df-body">
    <svg
      viewBox={`0 0 ${SVG_W} ${SVG_H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="df-svg"
      role="img"
      aria-label={title ?? 'Decision flow diagram'}
    >

      {/* ── Edges (rendered behind nodes) ──────────────────────────────── */}
      {edges.map(e => {
        const fr = pmap.get(e.from);
        const to = pmap.get(e.to);
        if (!fr || !to) return null;

        // Bezier: exits bottom-centre of parent, enters top-centre of child.
        const x1  = fr.cx;
        const y1  = fr.y + fr.h;              // bottom-centre of parent
        const x2  = to.cx;
        const y2  = to.y;                     // top-centre of child
        const gap = y2 - y1;
        const cp  = Math.max(gap * 0.45, 18); // bezier control-point offset
        const ARW = 8;                         // arrowhead height reserved at path end

        // Path ends ARW px above child top so the arrowhead tip lands exactly at y2.
        const d = `M ${x1} ${y1} C ${x1} ${y1 + cp}, ${x2} ${y2 - cp}, ${x2} ${y2 - ARW}`;

        // Edge label: placed near the start of the curve, offset away from the line.
        const goLeft  = x2 < x1 - 4;
        const goRight = x2 > x1 + 4;
        const lx      = x1 * 0.82 + x2 * 0.18;
        const ly      = y1 + gap * 0.14;
        const lxOff   = goLeft ? lx - 6 : lx + 6;
        const anchor: 'start' | 'end' = goLeft ? 'end' : 'start';

        const ec = eColor(e.label);
        const ew = eWidth(e.label);

        return (
          <>
            <path
              d={d}
              fill="none"
              stroke={ec}
              stroke-width={ew}
              stroke-linecap="round"
            />
            {/* Downward-pointing triangle arrowhead, tip at y2 */}
            <polygon
              points={`${x2 - 4},${y2 - ARW} ${x2 + 4},${y2 - ARW} ${x2},${y2 - 1}`}
              fill={ec}
            />
            {e.label && (
              <text
                x={lxOff}
                y={ly}
                text-anchor={anchor}
                class:list={[
                  'df-edge-label',
                  e.label === 'yes' && 'df-edge-label--yes',
                  e.label === 'no'  && 'df-edge-label--no',
                ]}
              >
                {e.label}
              </text>
            )}
          </>
        );
      })}

      {/* ── Nodes ──────────────────────────────────────────────────────────── */}
      {nodes.map(node => {
        const p    = pmap.get(node.id);
        if (!p) return null;

        const type = node.type    ?? 'decision';
        const v    = node.variant ?? 'neutral';
        const nx   = p.cx - NODE_W / 2;    // left edge of node rect

        // ── terminal ── pill shape ─────────────────────────────────────────
        if (type === 'terminal') {
          const isNeutral = v === 'neutral';
          const rx        = Math.min(p.h / 2, 22);
          const termStyle = !isNeutral
            ? `fill:${TERM_FILL[v]};stroke:${TERM_STROKE[v]};stroke-width:1.5`
            : undefined;
          const textStyle = TERM_TEXT[v] ? `fill:${TERM_TEXT[v]}` : undefined;

          return (
            <>
              <rect
                x={nx} y={p.y} width={NODE_W} height={p.h} rx={rx}
                class:list={['df-terminal-rect', isNeutral && 'df-terminal-rect--neutral']}
                style={termStyle}
              />
              {p.lines.map((line, i) => (
                <text
                  x={p.cx}
                  y={p.y + PAD_V + (i + 0.82) * LINE_H}
                  text-anchor="middle"
                  class="df-node-text df-node-text--terminal"
                  style={textStyle}
                >
                  {line}
                </text>
              ))}
            </>
          );
        }

        // ── action ── rect + left accent bar ──────────────────────────────
        if (type === 'action') {
          return (
            <>
              <rect x={nx} y={p.y} width={NODE_W} height={p.h} rx="7" class="df-node-rect" />
              <rect x={nx} y={p.y} width={3} height={p.h} rx="2" style={`fill:${ACCENT[v]}`} />
              {p.lines.map((line, i) => (
                <text
                  x={nx + TX_ACT}
                  y={p.y + PAD_V + (i + 0.82) * LINE_H}
                  class="df-node-text"
                >
                  {line}
                </text>
              ))}
            </>
          );
        }

        // ── decision (default) ── rect + ◆ indicator ──────────────────────
        // Diamond centred vertically in the node, 10 px from the left edge.
        const dcy = p.y + p.h / 2;
        return (
          <>
            <rect
              x={nx} y={p.y} width={NODE_W} height={p.h} rx="7"
              class="df-node-rect df-node-rect--decision"
            />
            {/* ◆ 10×10 diamond indicator */}
            <polygon
              points={`${nx + 5},${dcy} ${nx + 10},${dcy - 5} ${nx + 15},${dcy} ${nx + 10},${dcy + 5}`}
              class="df-diamond"
            />
            {p.lines.map((line, i) => (
              <text
                x={nx + TX_DEC}
                y={p.y + PAD_V + (i + 0.82) * LINE_H}
                class="df-node-text"
              >
                {line}
              </text>
            ))}
          </>
        );
      })}

    </svg>
  </div>

  {caption && <div class="df-caption">{caption}</div>}
</div>

<style>
  /* ── Shell ─────────────────────────────────────────────────────────────── */
  .df-wrap {
    margin: 2rem 0;
    border: 1px solid var(--theme-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .df-header {
    padding: 0.625rem 1.25rem;
    background: var(--theme-bg-raised);
    border-bottom: 1px solid var(--theme-line);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--theme-fg-faint);
  }

  .df-body {
    background: var(--theme-bg-inset);
    overflow-x: auto;
    padding: 0.75rem;
  }

  .df-caption {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    color: var(--theme-fg-faint);
    font-style: italic;
    text-align: center;
    border-top: 1px solid var(--theme-line);
    background: var(--theme-bg-raised);
  }

  /* ── SVG canvas ─────────────────────────────────────────────────────────── */
  .df-svg {
    display: block;
    width: 100%;
    height: auto;
    /* Horizontally scrollable on narrow viewports (same pattern as TokenTree) */
    min-width: 520px;
  }

  /* ── Decision node rect ─────────────────────────────────────────────────── */
  .df-node-rect {
    fill: var(--theme-bg-raised);
    stroke: var(--theme-line-strong);
    stroke-width: 1.5;
  }

  /* Decision nodes get a subtle indigo tint to signal "this is a question" */
  .df-node-rect--decision {
    fill: rgba(99, 102, 241, 0.05);
    stroke: rgba(99, 102, 241, 0.28);
  }

  /* ── Terminal (pill) node rect ──────────────────────────────────────────── */
  .df-terminal-rect {
    stroke-width: 1.5;
    /* Non-neutral variants override fill + stroke via inline style */
  }

  /* Neutral terminal — must use CSS class because SVG attributes can't
     interpolate CSS custom properties in all target browsers */
  .df-terminal-rect--neutral {
    fill: var(--theme-bg-raised);
    stroke: var(--theme-line-strong);
  }

  /* ── Diamond indicator (decision nodes) ─────────────────────────────────── */
  .df-diamond {
    fill: rgba(99, 102, 241, 0.45);
  }

  /* ── Node label text ────────────────────────────────────────────────────── */
  .df-node-text {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      'Segoe UI', Roboto, sans-serif;
    font-size: 11.5px;
    fill: var(--theme-fg-default);
  }

  .df-node-text--terminal {
    font-weight: 600;
    /* Non-neutral text colour set via inline style; neutral inherits fill above */
  }

  /* ── Edge labels ────────────────────────────────────────────────────────── */
  .df-edge-label {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      'Segoe UI', Roboto, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    fill: var(--theme-fg-ghost);
  }

  .df-edge-label--yes { fill: #4ade80; }
  .df-edge-label--no  { fill: var(--theme-fg-ghost); }
</style>

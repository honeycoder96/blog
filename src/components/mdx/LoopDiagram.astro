---
/**
 * LoopDiagram — N phases arranged in a clockwise ring with curved arrows.
 *
 * Use for cyclic processes: browser event loop, Atomics wait/notify cycles,
 * request/response loops, or any N-phase repeating sequence.
 *
 * Props:
 *   phases      — Phase[] in clockwise order; first phase is placed at the top
 *   title       — optional header label
 *   caption     — optional footer caption
 *   activeIndex — 0-based; draws a dashed accent ring around this phase
 */

type PhaseVariant = 'default' | 'accent' | 'warning';

interface Phase {
  label: string;
  /** Smaller monospace annotation rendered below the label */
  sublabel?: string;
  /** Short label placed on the curved arrow leading *into* this phase */
  arrowNote?: string;
  variant?: PhaseVariant;
}

interface Props {
  phases: Phase[];
  title?: string;
  caption?: string;
  activeIndex?: number;
}

const { phases, title, caption, activeIndex } = Astro.props;
const N   = phases.length;
const uid = `ld-${Math.random().toString(36).slice(2, 7)}`;

// ── Layout constants ─────────────────────────────────────────────────────────
const W   = 600;
const H   = 600;
const CX  = W / 2;
const CY  = H / 2;
// Ring radius scales with N so nodes don't overlap
const R   = N <= 3 ? 155 : N <= 5 ? 180 : 198;
const NW  = 148;   // node width
const NH  = 60;    // node height
const NRX = 9;     // node corner radius
const BR  = 10;    // badge circle radius
const EP  = 3;     // gap between node border and arrowhead tip

// ── Phase center positions (clockwise, starting at top) ──────────────────────
const pos = phases.map((_, i) => {
  const a = (i / N) * 2 * Math.PI - Math.PI / 2;
  return { x: CX + R * Math.cos(a), y: CY + R * Math.sin(a) };
});

// ── Edge point on node bounding ellipse (approximation for rounded rect) ─────
function edgePt(nx: number, ny: number, tx: number, ty: number) {
  const dx = tx - nx, dy = ty - ny;
  const d  = Math.sqrt(dx * dx + dy * dy);
  const ux = dx / d, uy = dy / d;
  const hw = NW / 2 + EP;
  const hh = NH / 2 + EP;
  const t  = 1 / Math.sqrt((ux / hw) ** 2 + (uy / hh) ** 2);
  return { x: nx + t * ux, y: ny + t * uy };
}

const f = (n: number) => n.toFixed(1);

// ── Arrow paths: phase[i] → phase[(i+1) % N] ─────────────────────────────────
// arrowNote on phase[i] describes the condition to *enter* phase[i],
// so it labels the arrow coming FROM phase[(i-1+N)%N].
const arrows = phases.map((_, i) => {
  const ni  = (i + 1) % N;
  const src = pos[i];
  const dst = pos[ni];

  const s   = edgePt(src.x, src.y, dst.x, dst.y);  // start: source node edge
  const e   = edgePt(dst.x, dst.y, src.x, src.y);  // end:   dest node edge

  // Control point: midpoint of (s, e) pushed outward from ring centre
  const mx  = (s.x + e.x) / 2;
  const my  = (s.y + e.y) / 2;
  const ox  = mx - CX;
  const oy  = my - CY;
  const od  = Math.sqrt(ox * ox + oy * oy);
  const k   = 34;  // outward push distance in px
  const cpx = mx + (ox / od) * k;
  const cpy = my + (oy / od) * k;

  // Arrow note label: slightly beyond the control point (further outward)
  const lx  = cpx + (ox / od) * 16;
  const ly  = cpy + (oy / od) * 16;

  return {
    d:    `M ${f(s.x)} ${f(s.y)} Q ${f(cpx)} ${f(cpy)} ${f(e.x)} ${f(e.y)}`,
    lx,
    ly,
    note: phases[ni].arrowNote ?? null,
  };
});

// ── Variant colour tokens passed as local CSS vars on each node <g> ───────────
const VC: Record<PhaseVariant, string> = {
  default: '--ld-nf:var(--ld-node-fill);--ld-ns:var(--ld-node-stroke);--ld-nt:var(--ld-node-text);--ld-nb:var(--ld-badge-fill)',
  accent:  '--ld-nf:var(--ld-accent-fill);--ld-ns:var(--ld-accent-stroke);--ld-nt:var(--ld-accent-text);--ld-nb:var(--ld-accent-stroke)',
  warning: '--ld-nf:var(--ld-warning-fill);--ld-ns:var(--ld-warning-stroke);--ld-nt:var(--ld-warning-text);--ld-nb:var(--ld-warning-stroke)',
};
---

<div class="ld-wrap">
  {title && <div class="ld-header">{title}</div>}

  <div class="ld-body">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="ld-svg"
      role="img"
      aria-label={title ?? 'Loop diagram'}
    >
      <defs>
        <marker
          id={`${uid}-ah`}
          markerWidth="9" markerHeight="9"
          refX="8" refY="4.5"
          orient="auto"
        >
          <path d="M 0 0.5 L 8.5 4.5 L 0 8.5 z" class="ld-arrowhead" />
        </marker>
      </defs>

      {/* ── Arrows (drawn behind nodes) ───────────────────────────────────── */}
      {arrows.map(arrow => (
        <>
          <path
            d={arrow.d}
            class="ld-arrow"
            marker-end={`url(#${uid}-ah)`}
          />
          {arrow.note && (
            <text
              x={arrow.lx}
              y={arrow.ly}
              text-anchor="middle"
              class="ld-note"
            >{arrow.note}</text>
          )}
        </>
      ))}

      {/* ── Nodes ────────────────────────────────────────────────────────── */}
      {phases.map((phase, i) => {
        const { x, y } = pos[i];
        const vs = VC[phase.variant ?? 'default'];

        return (
          <g style={vs}>
            {/* Active highlight ring */}
            {i === activeIndex && (
              <rect
                x={x - NW / 2 - 5} y={y - NH / 2 - 5}
                width={NW + 10} height={NH + 10}
                rx={NRX + 5}
                class="ld-active-ring"
              />
            )}

            {/* Node background */}
            <rect
              x={x - NW / 2} y={y - NH / 2}
              width={NW} height={NH}
              rx={NRX}
              fill="var(--ld-nf)"
              stroke="var(--ld-ns)"
              stroke-width="1.5"
            />

            {/* Number badge — sits on the top-left corner of the node */}
            <circle
              cx={x - NW / 2}
              cy={y - NH / 2}
              r={BR}
              fill="var(--ld-nb)"
            />
            <text
              x={x - NW / 2}
              y={y - NH / 2 + 4}
              text-anchor="middle"
              class="ld-badge-num"
            >{i + 1}</text>

            {/* Phase label */}
            <text
              x={x}
              y={phase.sublabel ? y - 5 : y + 5}
              text-anchor="middle"
              fill="var(--ld-nt)"
              class="ld-label"
            >{phase.label}</text>

            {/* Sub-label */}
            {phase.sublabel && (
              <text
                x={x}
                y={y + 14}
                text-anchor="middle"
                class="ld-sublabel"
              >{phase.sublabel}</text>
            )}
          </g>
        );
      })}
    </svg>
  </div>

  {caption && <div class="ld-caption">{caption}</div>}
</div>

<style is:global>
  /* ── Design tokens ───────────────────────────────────────────────────────── */
  :root {
    --ld-node-fill:   var(--theme-bg-raised);
    --ld-node-stroke: var(--theme-line-strong, #cbd5e1);
    --ld-node-text:   var(--theme-fg-default);
    --ld-badge-fill:  oklch(52% 0.20 262);

    --ld-accent-fill:   oklch(97% 0.01 150);
    --ld-accent-stroke: oklch(42% 0.15 150);
    --ld-accent-text:   oklch(35% 0.15 150);

    --ld-warning-fill:   oklch(97% 0.01 68);
    --ld-warning-stroke: oklch(50% 0.18 68);
    --ld-warning-text:   oklch(40% 0.18 68);

    --ld-arrow-color:       var(--theme-fg-ghost, #94a3b8);
    --ld-note-color:        var(--theme-fg-faint, #64748b);
    --ld-active-ring-color: oklch(58% 0.20 262);
  }

  [data-theme="dark"] {
    --ld-badge-fill:  oklch(65% 0.17 262);

    --ld-accent-fill:   oklch(20% 0.04 150);
    --ld-accent-stroke: oklch(68% 0.13 150);
    --ld-accent-text:   oklch(75% 0.13 150);

    --ld-warning-fill:   oklch(20% 0.04 68);
    --ld-warning-stroke: oklch(68% 0.15 68);
    --ld-warning-text:   oklch(75% 0.15 68);

    --ld-active-ring-color: oklch(70% 0.18 262);
  }

  /* ── Shell ───────────────────────────────────────────────────────────────── */
  .ld-wrap {
    margin: 2rem 0;
    border: 1px solid var(--theme-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .ld-header {
    padding: 0.625rem 1.25rem;
    background: var(--theme-bg-raised);
    border-bottom: 1px solid var(--theme-line);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--theme-fg-faint);
  }

  .ld-body {
    background: var(--theme-bg-inset);
    padding: 1rem;
    overflow-x: auto;
  }

  .ld-svg {
    display: block;
    width: 100%;
    height: auto;
    min-width: 300px;
    max-width: 520px;
    margin: 0 auto;
  }

  .ld-caption {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    color: var(--theme-fg-faint);
    font-style: italic;
    text-align: center;
    border-top: 1px solid var(--theme-line);
    background: var(--theme-bg-raised);
  }

  /* ── SVG elements ────────────────────────────────────────────────────────── */
  .ld-arrow {
    fill: none;
    stroke: var(--ld-arrow-color);
    stroke-width: 1.75;
  }

  .ld-arrowhead {
    fill: var(--ld-arrow-color);
  }

  .ld-active-ring {
    fill: none;
    stroke: var(--ld-active-ring-color);
    stroke-width: 2;
    stroke-dasharray: 4 3;
  }

  .ld-badge-num {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 700;
    fill: white;
  }

  .ld-label {
    font-family: "Clash Display", ui-sans-serif, system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
  }

  .ld-sublabel {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    fill: var(--ld-note-color);
  }

  .ld-note {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    fill: var(--ld-note-color);
    font-style: italic;
  }
</style>

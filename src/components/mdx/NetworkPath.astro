---
type NodeType = 'device' | 'router' | 'server' | 'dns' | 'isp' | 'cdn' | 'firewall' | 'ixp';

interface PathNode {
  id: string;
  label: string;
  sublabel?: string;
  type: NodeType;
  annotation?: string;
  highlight?: boolean;
}

interface PathEdge {
  from: string;
  to: string;
  label?: string;
  protocol?: string;
}

interface Props {
  nodes: PathNode[];
  edges: PathEdge[];
  title?: string;
  caption?: string;
  direction?: 'horizontal' | 'vertical';
}

const { nodes, edges, title, caption, direction = 'horizontal' } = Astro.props;

// ── SVG dimensions ─────────────────────────────────────────────────────────
const isHoriz = direction === 'horizontal';
const W = isHoriz ? 1000 : 400;

const NODE_BOX_W  = 110;
const NODE_BOX_H  = 68;
const NODE_ICON_S = 24; // icon bounding size
const ZONE_W      = isHoriz ? W / nodes.length : W;
const ZONE_H      = 120;

const SVG_W = isHoriz ? W : 400;
const SVG_H = isHoriz ? 180 : nodes.length * ZONE_H + 20;

function nodeCenter(i: number): [number, number] {
  if (isHoriz) return [(i + 0.5) * ZONE_W, SVG_H / 2 - 10];
  return [SVG_W / 2, 60 + i * ZONE_H];
}

// ── Node colour per type ────────────────────────────────────────────────────
const TYPE_COLOR: Record<NodeType, { fill: string; stroke: string; icon: string }> = {
  device:   { fill: 'rgba(99,102,241,0.1)',  stroke: 'rgba(99,102,241,0.45)',  icon: '#818cf8' },
  router:   { fill: 'rgba(59,130,246,0.1)',  stroke: 'rgba(59,130,246,0.45)',  icon: '#60a5fa' },
  server:   { fill: 'rgba(34,197,94,0.1)',   stroke: 'rgba(34,197,94,0.45)',   icon: '#4ade80' },
  dns:      { fill: 'rgba(168,85,247,0.1)',  stroke: 'rgba(168,85,247,0.45)',  icon: '#c084fc' },
  isp:      { fill: 'rgba(249,115,22,0.1)',  stroke: 'rgba(249,115,22,0.45)',  icon: '#fb923c' },
  cdn:      { fill: 'rgba(236,72,153,0.1)',  stroke: 'rgba(236,72,153,0.45)', icon: '#f472b6' },
  firewall: { fill: 'rgba(239,68,68,0.1)',   stroke: 'rgba(239,68,68,0.45)',   icon: '#f87171' },
  ixp:      { fill: 'rgba(20,184,166,0.1)',  stroke: 'rgba(20,184,166,0.45)',  icon: '#2dd4bf' },
};

// ── SVG icon paths (centred on 0,0; rendered with translate) ───────────────
function iconPath(type: NodeType): string {
  switch (type) {
    case 'device':
      // Laptop: screen + base
      return 'M-10,-10 L10,-10 L10,4 L-10,4 Z M-12,6 L12,6 L8,10 L-8,10 Z M-7,-7 L7,-7 L7,1 L-7,1 Z';
    case 'router':
      // Hub: centre circle + 4 radiating lines
      return 'M0,-11 L0,-4 M0,4 L0,11 M-11,0 L-4,0 M4,0 L11,0 M0,0 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0';
    case 'server':
      // Three rack units
      return 'M-10,-11 L10,-11 L10,-5 L-10,-5 Z M-10,-3 L10,-3 L10,3 L-10,3 Z M-10,5 L10,5 L10,11 L-10,11 Z M7,-8 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 M7,0 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 M7,8 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0';
    case 'dns':
      // Database cylinder
      return 'M-9,-8 Q-9,-12 0,-12 Q9,-12 9,-8 L9,8 Q9,12 0,12 Q-9,12 -9,8 Z M-9,-8 Q-9,-4 0,-4 Q9,-4 9,-8 M-9,2 Q-9,6 0,6 Q9,6 9,2';
    case 'isp':
      // Building
      return 'M-9,11 L-9,-9 L9,-9 L9,11 Z M-6,-13 L6,-13 L6,-9 L-6,-9 Z M-6,2 L-2,2 L-2,11 L-6,11 Z M2,2 L6,2 L6,11 L2,11 Z M-6,-6 L-3,-6 L-3,-3 L-6,-3 Z M1,-6 L4,-6 L4,-3 L1,-3 Z';
    case 'cdn':
      // Cloud
      return 'M-8,4 Q-12,4 -12,-1 Q-12,-6 -7,-6 Q-7,-11 -1,-11 Q4,-11 5,-7 Q9,-7 9,-3 Q9,4 4,4 Z';
    case 'firewall':
      // Shield
      return 'M0,-12 L10,-7 L10,2 L0,12 L-10,2 L-10,-7 Z M0,-8 L0,4 M-5,-2 L5,-2';
    case 'ixp':
      // Interconnect crosshair
      return 'M-11,0 L11,0 M0,-11 L0,11 M-7,-7 L7,7 M7,-7 L-7,7 M0,0 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0';
    default:
      return 'M-8,-8 L8,-8 L8,8 L-8,8 Z';
  }
}

// ── Build edge index ────────────────────────────────────────────────────────
const edgesWithPos = edges.map(edge => {
  const fromIdx = nodes.findIndex(n => n.id === edge.from);
  const toIdx   = nodes.findIndex(n => n.id === edge.to);
  if (fromIdx < 0 || toIdx < 0) return null;
  const [x1, y1] = nodeCenter(fromIdx);
  const [x2, y2] = nodeCenter(toIdx);

  // Offset so lines don't pass through the box
  const dx = x2 - x1; const dy = y2 - y1;
  const dist = Math.sqrt(dx * dx + dy * dy) || 1;
  const off  = NODE_BOX_W / 2 + 4;
  const ux   = dx / dist; const uy = dy / dist;

  return {
    ...edge,
    x1: x1 + ux * off, y1: y1 + uy * off,
    x2: x2 - ux * off, y2: y2 - uy * off,
    midX: (x1 + x2) / 2,
    midY: (y1 + y2) / 2 - 10,
  };
}).filter(Boolean) as Array<{ from: string; to: string; label?: string; protocol?: string; x1: number; y1: number; x2: number; y2: number; midX: number; midY: number }>;

const uid = `np-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="np-wrap">
  {title && <div class="np-header">{title}</div>}
  <div class="np-body">
    <svg
      viewBox={`0 0 ${SVG_W} ${SVG_H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="np-svg"
      role="img"
      aria-label={title ?? 'Network path diagram'}
    >
      <defs>
        <marker id={`${uid}-arr`} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <polygon points="0 0, 8 4, 0 8" fill="var(--theme-line-strong)" />
        </marker>
      </defs>

      {/* ── Edges ──────────────────────────────────────────────────── */}
      {edgesWithPos.map(e => (
        <>
          <line
            x1={e.x1} y1={e.y1}
            x2={e.x2} y2={e.y2}
            class="np-edge"
            marker-end={`url(#${uid}-arr)`}
          />
          {(e.label || e.protocol) && (
            <text x={e.midX} y={e.midY} class="np-edge-label" text-anchor="middle">
              {e.protocol ? `${e.label ?? ''} (${e.protocol})` : e.label}
            </text>
          )}
        </>
      ))}

      {/* ── Nodes ──────────────────────────────────────────────────── */}
      {nodes.map((node, i) => {
        const [cx, cy] = nodeCenter(i);
        const bx = cx - NODE_BOX_W / 2;
        const by = cy - NODE_BOX_H / 2;
        const c  = TYPE_COLOR[node.type];
        const hasSubLabel = !!node.sublabel;
        const iconY = hasSubLabel ? cy - 14 : cy - 10;
        const labelY = hasSubLabel ? cy + 6  : cy + 12;
        const subY   = cy + 20;

        return (
          <>
            {/* Box */}
            <rect
              x={bx} y={by}
              width={NODE_BOX_W} height={NODE_BOX_H}
              rx="8"
              fill={c.fill}
              stroke={node.highlight ? c.icon : c.stroke}
              stroke-width={node.highlight ? 2.5 : 1.5}
            />

            {/* Icon */}
            <g transform={`translate(${cx}, ${iconY})`}>
              <path d={iconPath(node.type)} fill="none" stroke={c.icon} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </g>

            {/* Label */}
            <text x={cx} y={labelY} class="np-node-label" text-anchor="middle">{node.label}</text>
            {node.sublabel && (
              <text x={cx} y={subY} class="np-node-sub" text-anchor="middle">{node.sublabel}</text>
            )}

            {/* Annotation badge */}
            {node.annotation && (
              <>
                <rect
                  x={cx - 46} y={by - 22}
                  width={92} height={18}
                  rx="4"
                  fill="rgba(245,158,11,0.12)"
                  stroke="rgba(245,158,11,0.35)"
                  stroke-width="1"
                />
                <text x={cx} y={by - 10} class="np-annotation" text-anchor="middle">{node.annotation}</text>
              </>
            )}
          </>
        );
      })}
    </svg>
  </div>
  {caption && <div class="np-caption">{caption}</div>}
</div>

<style>
  .np-wrap {
    margin: 2rem 0;
    border: 1px solid var(--theme-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .np-header {
    padding: 0.625rem 1.25rem;
    background: var(--theme-bg-raised);
    border-bottom: 1px solid var(--theme-line);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--theme-fg-faint);
  }

  .np-body {
    background: var(--theme-bg-inset);
    overflow-x: auto;
    padding: 0.75rem;
  }

  .np-svg {
    display: block;
    width: 100%;
    height: auto;
    min-width: 360px;
  }

  .np-edge {
    stroke: var(--theme-line-strong);
    stroke-width: 1.75;
  }

  .np-edge-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    fill: var(--theme-fg-ghost);
  }

  .np-node-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 700;
    fill: var(--theme-fg-default);
  }

  .np-node-sub {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 9.5px;
    fill: var(--theme-fg-faint);
  }

  .np-annotation {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 9px;
    font-weight: 600;
    fill: #f59e0b;
  }

  .np-caption {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    color: var(--theme-fg-faint);
    font-style: italic;
    text-align: center;
    border-top: 1px solid var(--theme-line);
    background: var(--theme-bg-raised);
  }
</style>

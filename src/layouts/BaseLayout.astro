---
import '../styles/global.css';
import { CustomCursor } from '../components/react/ui/CustomCursor';
import { SearchModal } from '../components/react/ui/SearchModal';
import { BackToTop } from '../components/react/ui/BackToTop';
import { ViewTransitions } from 'astro:transitions';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** 'article' on blog/series post pages; defaults to 'website' */
  ogType?: 'website' | 'article';
  /** ISO 8601 publish date — used for og:article:published_time (article pages only) */
  publishedTime?: string;
  /** Post tags — used for og:article:tag (article pages only) */
  articleTags?: string[];
  /** When true, injects noindex/nofollow robots meta (hidden posts) */
  noindex?: boolean;
  /** JSON-LD structured data as a pre-serialised string */
  jsonLd?: string;
}

const {
  title,
  description = siteConfig.description,
  ogImage,
  ogType = 'website',
  publishedTime,
  articleTags = [],
  noindex = false,
  jsonLd,
} = Astro.props;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImageURL = ogImage && Astro.site ? new URL(ogImage, Astro.site).href : undefined;
const gaMeasurementId = siteConfig.analytics.gaMeasurementId;
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Canonical URL -->
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- RSS feed -->
    <link rel="alternate" type="application/rss+xml" title={siteConfig.rss.title} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {ogImageURL && <meta property="og:image:width" content="1200" />}
    {ogImageURL && <meta property="og:image:height" content="630" />}
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && <meta property="article:author" content={siteConfig.author} />}
    {ogType === 'article' && articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card (E) -->
    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:site" content={siteConfig.social.twitter} />
    <meta name="twitter:creator" content={siteConfig.social.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- JSON-LD structured data (A) -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    <!-- Flash prevention: set theme before paint and after every View Transition swap -->
    <script is:inline>
      (function() {
        function applyTheme() {
          var theme = localStorage.getItem('theme') || 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        }
        applyTheme();
        // astro:after-swap fires after the new page's <html> attributes are applied,
        // which resets data-theme to the hardcoded default — re-apply from localStorage.
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- View Transitions -->
    <!-- fallback="swap" — on browsers without native View Transitions support,
         swap content instantly instead of running Astro's JS animation fallback.
         The JS fallback reads layout geometry (offsetWidth etc.) causing forced
         reflows. Modern browsers (Chrome 111+, Safari 18+) use the native API
         which the browser handles without any JS-side geometry queries. -->
    <ViewTransitions fallback="swap" />

    <!-- Self-hosted fonts — preload critical weights (I) -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/clash-display-700.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-500.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-700.woff2" crossorigin />

    <!-- Google Analytics 4 — async, non-blocking -->
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaMeasurementId, { send_page_view: false });
          document.addEventListener('astro:page-load', function () {
            gtag('event', 'page_view', {
              page_location: window.location.href,
              page_title: document.title,
            });
          });
        </script>
      </>
    )}
  </head>
  <body class="bg-surface text-fg font-sans">
    <CustomCursor client:idle />
    <SearchModal client:idle />
    <BackToTop client:idle />
    <slot />
  </body>
</html>

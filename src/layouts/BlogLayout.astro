---
import PageLayout from './PageLayout.astro';
import { ReadingProgress } from '../components/react/blog/ReadingProgress';
import { TableOfContents } from '../components/react/blog/TableOfContents';
import { MobileSidebar } from '../components/react/blog/MobileSidebar';
import CategoryBadge from '../components/astro/CategoryBadge.astro';
import AuthorBio from '../components/astro/AuthorBio.astro';
import { siteConfig } from '../config/site';

interface PostLink {
  slug: string;
  title: string;
  href?: string;
}

interface RelatedPost {
  slug: string;
  title: string;
  category: string;
}

interface SeriesContext {
  seriesSlug: string;
  seriesTitle: string;
  part: number;
  total: number;
}

interface Props {
  title: string;
  description?: string;
  date: string;
  pubDate?: Date;
  category: string;
  author: string;
  readingTime?: number;
  tags?: string[];
  isVisible?: boolean;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: PostLink;
  nextPost?: PostLink;
  relatedPosts?: RelatedPost[];
  seriesContext?: SeriesContext;
  ogImage?: string;
}

const {
  title, description, date, pubDate, category, author, readingTime,
  tags = [], isVisible = true, headings, prevPost, nextPost,
  relatedPosts = [], seriesContext, ogImage,
} = Astro.props;
const hasPostNav = prevPost || nextPost;
const { themeDark, themeLight } = siteConfig.comments.giscus;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImageURL = ogImage && Astro.site ? new URL(ogImage, Astro.site).href : undefined;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? '',
  author: { '@type': 'Person', name: author },
  datePublished: pubDate?.toISOString() ?? '',
  ...(ogImageURL ? { image: ogImageURL } : {}),
  ...(canonicalURL ? { url: canonicalURL } : {}),
  ...(readingTime ? { timeRequired: `PT${readingTime}M` } : {}),
  keywords: [category, ...tags].join(', '),
  publisher: {
    '@type': 'Person',
    name: siteConfig.author,
    url: Astro.site?.href ?? '',
  },
});
---

<PageLayout
  title={`${title} — ${siteConfig.author}`}
  description={description}
  ogImage={ogImage}
  ogType="article"
  publishedTime={pubDate?.toISOString()}
  articleTags={[category, ...tags]}
  noindex={!isVisible}
  jsonLd={jsonLd}
>
  <ReadingProgress client:idle />
  <MobileSidebar headings={headings} relatedPosts={relatedPosts} client:idle />

  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16 w-full">
    <!-- Top prev/next nav -->
    {hasPostNav && (
      <nav class="max-w-3xl flex justify-between items-center mb-6" aria-label="Post navigation">
        {prevPost ? (
          <a
            href={prevPost.href ?? `/blog/${prevPost.slug}`}
            class="flex items-center gap-1.5 font-mono text-xs uppercase tracking-widest text-fg-faint hover:text-fg transition-colors"
          >
            <span aria-hidden="true">&larr;</span> Prev
          </a>
        ) : <span />}
        {nextPost ? (
          <a
            href={nextPost.href ?? `/blog/${nextPost.slug}`}
            class="flex items-center gap-1.5 font-mono text-xs uppercase tracking-widest text-fg-faint hover:text-fg transition-colors"
          >
            Next <span aria-hidden="true">&rarr;</span>
          </a>
        ) : <span />}
      </nav>
    )}

    <!-- Article header -->
    <header class="max-w-3xl mb-16">
      {seriesContext && (
        <div class="flex items-center gap-3 mb-4 font-mono text-xs text-fg-faint uppercase tracking-widest">
          <a href="/series" class="hover:text-fg transition-colors">Series</a>
          <span>/</span>
          <a href={`/series/${seriesContext.seriesSlug}`} class="hover:text-fg transition-colors">
            {seriesContext.seriesTitle}
          </a>
          <span class="ml-2 flex gap-1.5 items-center">
            {Array.from({ length: seriesContext.total }, (_, i) => (
              <span class={`w-1.5 h-1.5 rounded-full ${i + 1 === seriesContext.part ? 'bg-fg' : 'bg-line-strong'}`} />
            ))}
            <span class="ml-1">Part {seriesContext.part} of {seriesContext.total}</span>
          </span>
        </div>
      )}
      <div class="flex items-center gap-4 mb-6">
        <CategoryBadge category={category} />
        {readingTime && (
          <span class="text-fg-faint font-mono text-xs">{readingTime} min read</span>
        )}
      </div>
      <h1 data-pagefind-meta="title" class="text-4xl md:text-6xl font-display font-bold tracking-tight text-fg leading-tight mb-6">
        {title}
      </h1>
      {description && (
        <p class="text-xl text-fg-muted leading-relaxed mb-8">{description}</p>
      )}
      <div class="flex items-center gap-6 text-sm font-mono text-fg-faint uppercase tracking-widest">
        <span>{author}</span>
        <span class="w-px h-4 bg-line"></span>
        <time data-pagefind-meta="date">{date}</time>
      </div>
      <span data-pagefind-filter={`category[${category}]`} class="hidden" />
    </header>

    <!-- Content + TOC layout -->
    <div class="flex gap-20 relative">
      <!-- Main content -->
      <article data-pagefind-body class="flex-1 min-w-0 prose-invert max-w-3xl">
        <slot />
      </article>

      <!-- Sticky sidebar: TOC + Related -->
      {(headings.filter(h => h.depth <= 2).length > 0 || relatedPosts.length > 0) && (
        <aside data-pagefind-ignore class="hidden xl:block w-64 shrink-0">
          <div class="sticky top-32">
            {headings.filter(h => h.depth <= 2).length > 0 && (
              <TableOfContents headings={headings} client:idle />
            )}

            {relatedPosts.length > 0 && (
              <nav class={headings.filter(h => h.depth <= 2).length > 0 ? 'mt-10 pt-8 border-t border-line-faint' : ''}>
                <p class="text-xs font-mono uppercase tracking-widest text-fg-faint mb-4">
                  Related Reading
                </p>
                <ul class="flex flex-col gap-3">
                  {relatedPosts.map((related) => (
                    <li>
                      <a
                        href={`/blog/${related.slug}`}
                        class="group block"
                      >
                        <span class="text-[10px] font-mono text-fg-faint uppercase tracking-wider block mb-0.5">
                          {related.category}
                        </span>
                        <span class="text-sm text-fg-muted group-hover:text-fg transition-colors leading-snug block">
                          {related.title}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            )}
          </div>
        </aside>
      )}
    </div>

    <!-- Author bio -->
    <AuthorBio author={author} />

    <!-- Bottom prev/next cards -->
    {hasPostNav && (
      <nav class="max-w-3xl grid grid-cols-2 gap-6 mt-16 pt-12 border-t border-line-faint" aria-label="Previous and next posts">
        {prevPost ? (
          <a
            href={prevPost.href ?? `/blog/${prevPost.slug}`}
            class="group p-6 rounded-2xl border border-line hover:border-line-strong transition-colors bg-surface-raised/50"
          >
            <span class="text-xs font-mono text-fg-faint uppercase tracking-wider block mb-2">
              &larr; Previous Post
            </span>
            <span class="font-display font-bold text-fg-default group-hover:text-fg transition-colors leading-tight block">
              {prevPost.title}
            </span>
          </a>
        ) : <span />}
        {nextPost ? (
          <a
            href={nextPost.href ?? `/blog/${nextPost.slug}`}
            class="group p-6 rounded-2xl border border-line hover:border-line-strong transition-colors bg-surface-raised/50 text-right col-start-2"
          >
            <span class="text-xs font-mono text-fg-faint uppercase tracking-wider block mb-2">
              Next Post &rarr;
            </span>
            <span class="font-display font-bold text-fg-default group-hover:text-fg transition-colors leading-tight block">
              {nextPost.title}
            </span>
          </a>
        ) : <span />}
      </nav>
    )}

    <!-- Comments (Giscus) — configured via siteConfig.comments.giscus -->
    <div class="max-w-3xl mt-16 pt-12 border-t border-line-faint">
      <!--
        Setup script runs before Giscus initialises (lazy-loaded on scroll).
        1. Reads the current blog theme from <html data-theme> and sets the
           correct Giscus theme on the script tag before Giscus boots.
        2. Watches for theme changes via MutationObserver and forwards them
           to the already-loaded Giscus iframe via postMessage.
      -->
      <script is:inline id="giscus-script"
        src="https://giscus.app/client.js"
        data-repo={siteConfig.comments.giscus.repo}
        data-repo-id={siteConfig.comments.giscus.repoId}
        data-category={siteConfig.comments.giscus.category}
        data-category-id={siteConfig.comments.giscus.categoryId}
        data-mapping={siteConfig.comments.giscus.mapping}
        data-strict={siteConfig.comments.giscus.strict ? '1' : '0'}
        data-reactions-enabled={siteConfig.comments.giscus.reactionsEnabled ? '1' : '0'}
        data-emit-metadata="0"
        data-input-position={siteConfig.comments.giscus.inputPosition}
        data-theme="dark"
        data-lang={siteConfig.comments.giscus.lang}
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>

      <script is:inline define:vars={{ themeDark, themeLight }}>
        (function () {
          var script = document.getElementById('giscus-script');

          function resolveTheme() {
            return document.documentElement.getAttribute('data-theme') === 'light'
              ? themeLight
              : themeDark;
          }

          // Set the correct theme before Giscus lazy-loads
          if (script) script.setAttribute('data-theme', resolveTheme());

          // Forward theme changes to the Giscus iframe after it has loaded
          new MutationObserver(function () {
            var iframe = document.querySelector('iframe.giscus-frame');
            if (iframe) {
              iframe.contentWindow.postMessage(
                { giscus: { setConfig: { theme: resolveTheme() } } },
                'https://giscus.app',
              );
            }
          }).observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['data-theme'],
          });
        })();
      </script>

      <div class="giscus" />
    </div>
  </div>
</PageLayout>

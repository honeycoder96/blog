---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { resolveReadingTime, getRelatedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const publishedPosts = posts.filter((post) => !post.data.draft);

  // #23 — validate relatedPosts slug references at build time
  const validSlugs = new Set(publishedPosts.map((p) => p.slug));
  const errors: string[] = [];
  for (const post of publishedPosts) {
    for (const ref of post.data.relatedPosts) {
      if (!validSlugs.has(ref)) {
        errors.push(`  "${post.slug}" → relatedPosts references unknown slug: "${ref}"`);
      }
    }
  }
  if (errors.length > 0) {
    throw new Error(`Build failed — broken relatedPosts references:\n${errors.join('\n')}`);
  }

  return publishedPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const readingTime = resolveReadingTime(post.data.readingTime, post.body);

const allPosts = await getCollection('blog');

// Prev / Next posts
const prevPost = post.data.prevPost
  ? allPosts.find((p) => p.slug === post.data.prevPost)
  : undefined;
const nextPost = post.data.nextPost
  ? allPosts.find((p) => p.slug === post.data.nextPost)
  : undefined;

// Related posts — scores by tag overlap + category, prefers manual frontmatter
const relatedPosts = getRelatedPosts(post, allPosts);
---

<BlogLayout
  title={post.data.title}
  description={post.data.summary}
  date={post.data.date}
  pubDate={post.data.pubDate}
  category={post.data.category}
  author={post.data.author}
  readingTime={readingTime}
  tags={post.data.tags}
  isVisible={post.data.isVisible}
  headings={headings}
  prevPost={prevPost ? { slug: prevPost.slug, title: prevPost.data.title } : undefined}
  nextPost={nextPost ? { slug: nextPost.slug, title: nextPost.data.title } : undefined}
  relatedPosts={relatedPosts.map((r) => ({ slug: r.slug, title: r.data.title, category: r.data.category }))}
  ogImage={`/og/blog/${post.slug}.png`}
>
  <Content />
</BlogLayout>

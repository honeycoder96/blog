---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Related posts
const allPosts = await getCollection('blog');
const relatedPosts = post.data.relatedPosts.length
  ? allPosts.filter((p) => post.data.relatedPosts.includes(p.slug)).slice(0, 2)
  : allPosts
      .filter((p) => p.slug !== post.slug && p.data.category === post.data.category)
      .slice(0, 2);
---

<BlogLayout
  title={post.data.title}
  description={post.data.summary}
  date={post.data.date}
  category={post.data.category}
  author={post.data.author}
  readingTime={post.data.readingTime}
  headings={headings}
>
  <Content />

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="mt-24 pt-12 border-t border-neutral-900">
      <h3 class="text-sm font-mono uppercase tracking-widest text-neutral-600 mb-8">
        Related Reading
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPosts.map((related) => (
          <a
            href={`/blog/${related.slug}`}
            class="group p-6 rounded-2xl border border-neutral-800 hover:border-neutral-600 transition-colors bg-neutral-900/50"
          >
            <span class="text-xs font-mono text-neutral-600 uppercase tracking-wider block mb-2">
              {related.data.category}
            </span>
            <h4 class="font-display font-bold text-neutral-300 group-hover:text-white transition-colors leading-tight">
              {related.data.title}
            </h4>
            <p class="text-sm text-neutral-600 mt-2 line-clamp-2">{related.data.summary}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</BlogLayout>

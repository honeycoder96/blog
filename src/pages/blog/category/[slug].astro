---
import PageLayout from '../../../layouts/PageLayout.astro';
import { PostsGrid } from '../../../components/react/blog/PostsGrid';
import { AnimatedTitle } from '../../../components/react/ui/AnimatedTitle';
import CategoryFilterNav from '../../../components/astro/CategoryFilterNav.astro';
import { buildFilterCategories, slugifyCategory } from '../../../config/categories';
import { siteConfig } from '../../../config/site';
import { getPublishedPosts, mapPostToDisplay, countByCategory } from '../../../lib/content';

const PAGE_SIZE = 10;

export async function getStaticPaths() {
  const allVisible = await getPublishedPosts();
  const uniqueCategories = [...new Set(allVisible.map((p) => p.data.category))];
  return uniqueCategories.map((category) => ({
    params: { slug: slugifyCategory(category) },
    props: { category },
  }));
}

const { category } = Astro.props;

const allVisible = await getPublishedPosts();
const categoryPosts = allVisible
  .filter((p) => p.data.category === category)
  .map(mapPostToDisplay);

const initialPosts = categoryPosts.slice(0, PAGE_SIZE);
const totalPosts = categoryPosts.length;
const categories = buildFilterCategories(allVisible.map((p) => p.data.category));
const categoryCounts = countByCategory(allVisible.map((p) => p.data.category));
---

<PageLayout
  title={`${category} — ${siteConfig.author}`}
  description={`All ${category} posts on web engineering, architecture, and the craft of software.`}
>
  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16">
    <header class="mb-16">
      <AnimatedTitle
        text={category}
        className="text-5xl md:text-7xl font-display font-bold tracking-tighter text-fg mb-6"
        client:visible
      />
      <p class="text-xl text-fg-muted max-w-2xl">
        {totalPosts} {totalPosts === 1 ? 'article' : 'articles'} in this category.
      </p>
    </header>

    <CategoryFilterNav
      categories={categories}
      categoryCounts={categoryCounts}
      activeCategory={category}
    />

    <PostsGrid
      initialPosts={initialPosts}
      initialTotal={totalPosts}
      category={category}
      client:idle
    />
  </div>
</PageLayout>

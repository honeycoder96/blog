---
import PageLayout from '../../layouts/PageLayout.astro';
import { PostsGrid } from '../../components/react/blog/PostsGrid';
import { AnimatedTitle } from '../../components/react/ui/AnimatedTitle';
import { getCollection } from 'astro:content';
import { buildFilterCategories } from '../../config/categories';

const PAGE_SIZE = 10;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.isVisible !== false)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: p.slug,
    data: {
      title: p.data.title,
      date: p.data.date,
      category: p.data.category,
      summary: p.data.summary,
      readingTime: p.data.readingTime,
      tags: p.data.tags,
    },
  }));

// Only the first page is baked into the HTML.
// Everything after that is fetched from /api/posts/[category]/[page].json
const initialPosts = posts.slice(0, PAGE_SIZE);
const totalPosts = posts.length;
const categories = buildFilterCategories(posts.map((p) => p.data.category));
---

<PageLayout
  title="All Posts — Honey Sharma"
  description="All articles about web architecture, engineering, and the craft of software."
>
  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16">
    <header class="mb-16">
      <AnimatedTitle
        text="All Posts"
        className="text-5xl md:text-7xl font-display font-bold tracking-tighter text-fg mb-6"
        client:visible
      />
      <p class="text-xl text-fg-muted max-w-2xl">
        {totalPosts} articles on architecture, deep dives, and engineering culture.
      </p>
    </header>

    <PostsGrid
      initialPosts={initialPosts}
      initialTotal={totalPosts}
      categories={categories}
      client:idle
    />
  </div>
</PageLayout>

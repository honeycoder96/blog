---
import PageLayout from '../../layouts/PageLayout.astro';
import { PostsGrid } from '../../components/react/blog/PostsGrid';
import { AnimatedTitle } from '../../components/react/ui/AnimatedTitle';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.isVisible !== false)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: p.slug,
    data: {
      title: p.data.title,
      date: p.data.date,
      category: p.data.category,
      summary: p.data.summary,
      readingTime: p.data.readingTime,
      tags: p.data.tags,
    },
  }));
---

<PageLayout
  title="All Posts — Honey Sharma"
  description="All articles about web architecture, engineering, and the craft of software."
>
  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16">
    <header class="mb-16">
      <AnimatedTitle
        text="All Posts"
        className="text-5xl md:text-7xl font-display font-bold tracking-tighter text-fg mb-6"
        client:visible
      />
      <p class="text-xl text-fg-muted max-w-2xl">
        {posts.length} articles on architecture, deep dives, and engineering culture.
      </p>
    </header>

    <PostsGrid posts={posts} client:load />
  </div>
</PageLayout>

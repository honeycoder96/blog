---
import PageLayout from '../layouts/PageLayout.astro';
import { AnimatedTitle } from '../components/react/ui/AnimatedTitle';
import { ContactForm } from '../components/react/sections/ContactForm';
---

<PageLayout
  title="Contact — Honey Sharma"
  description="Get in touch to collaborate or say hello."
>
  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16 flex-1">
    <div class="mb-16">
      <AnimatedTitle
        text="Let's Collaborate"
        className="text-5xl md:text-7xl font-display font-bold tracking-tighter text-fg mb-6"
        client:visible
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
      <!-- Info -->
      <div class="flex flex-col justify-between">
        <div>
          <p class="text-xl text-fg-muted leading-relaxed max-w-md">
            Open to collaborating on projects where thoughtful design meets strong engineering.
            If you're building something interesting, let's talk.
          </p>

          <div class="mt-12 space-y-3">
            <a
              href="mailto:contact@honeyhimself.com"
              class="flex items-center gap-3 text-fg-muted hover:text-fg transition-colors font-mono text-sm"
            >
              <span class="w-12 text-fg-ghost">Email</span>
              contact@honeyhimself.com
            </a>
            <a
              href="https://github.com/honeycoder96"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-fg-muted hover:text-fg transition-colors font-mono text-sm"
            >
              <span class="w-12 text-fg-ghost">GitHub</span>
              @honeycoder96
            </a>
          </div>
        </div>

        <div class="flex flex-col gap-1 font-mono text-sm mt-12 text-fg-ghost tracking-widest uppercase">
          <span>Timezone: UTC+5:30</span>
          <span>Response time: 6-12h</span>
        </div>
      </div>

      <!-- Form: client:load — user may interact immediately -->
      <ContactForm client:load />
    </div>
  </div>
</PageLayout>

---
import PageLayout from '../layouts/PageLayout.astro';
import { HeroSection } from '../components/react/sections/HeroSection';
import { FeaturedPostsList } from '../components/react/blog/FeaturedPostsList';
import { CategoriesSection } from '../components/react/sections/CategoriesSection';
import { NewsletterSection } from '../components/react/sections/NewsletterSection';
import { HOMEPAGE_CATEGORIES } from '../config/categories';
import { siteConfig } from '../config/site';
import { getPublishedPosts, countByCategory } from '../lib/content';

const sorted = await getPublishedPosts();
const categoryCounts = countByCategory(sorted.map((p) => p.data.category));
const featuredPost = sorted.find((p) => p.data.featured);
const featuredPosts = sorted
  .filter((p) => p.data.featured)
  .map((p) => ({
    slug: p.slug,
    data: {
      title: p.data.title,
      date: p.data.date,
      category: p.data.category,
      author: p.data.author,
      summary: p.data.summary,
      readingTime: p.data.readingTime,
    },
  }));

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: siteConfig.siteName,
      url: siteConfig.siteUrl,
      description: siteConfig.description,
      author: { '@type': 'Person', name: siteConfig.author },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteConfig.siteUrl}/blog?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Person',
      name: siteConfig.author,
      url: siteConfig.social.website,
      sameAs: [
        siteConfig.social.github,
        siteConfig.social.linkedin,
        `https://twitter.com/${siteConfig.social.twitter.replace('@', '')}`,
      ],
      jobTitle: 'Software Engineer',
      description: siteConfig.bio,
      email: siteConfig.social.email,
    },
  ],
});
---

<PageLayout title={siteConfig.siteTitle} jsonLd={jsonLd}>
  <div class="px-8 lg:px-24">
    <div class="max-w-7xl mx-auto">
      <!-- Hero -->
      <HeroSection />

      <!-- Featured post card -->
      {featuredPost && (
        <div class="mb-24">
          <p class="font-mono text-xs text-fg-faint uppercase tracking-widest mb-6">
            Featured Post
          </p>
          <a
            href={`/blog/${featuredPost.slug}`}
            class="group block rounded-2xl bg-surface-raised/60 border border-line p-8 md:p-10 hover:border-line-strong transition-colors duration-300"
          >
            <div class="flex flex-wrap items-center gap-4 mb-6 font-mono text-sm text-fg-muted">
              <span class="px-3 py-1 rounded-full border border-line-strong text-xs uppercase tracking-wider text-fg-muted">
                {featuredPost.data.category}
              </span>
              <span>{featuredPost.data.date}</span>
              {featuredPost.data.readingTime && (
                <span>· {featuredPost.data.readingTime} min read</span>
              )}
            </div>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-fg leading-tight mb-5 group-hover:text-fg-default transition-colors max-w-3xl">
              {featuredPost.data.title}
            </h2>
            <p class="text-fg-muted leading-relaxed max-w-2xl">
              {featuredPost.data.summary}
            </p>
            <div class="flex items-center gap-2 mt-8 font-mono text-sm font-bold uppercase tracking-widest text-fg">
              Read Article
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </div>
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Featured writing section -->
  <section class="py-32 px-8 lg:px-24 border-t border-line-faint relative">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
          <h2 class="text-4xl font-display font-bold tracking-tight text-fg mb-4">
            Featured Writing
          </h2>
          <p class="text-fg-muted text-lg">
            Deep dives into patterns, performance, and engineering culture.
          </p>
        </div>
        <a
          href="/blog"
          class="magnetic flex items-center gap-2 text-fg/80 hover:text-fg pb-2 border-b border-fg/20 hover:border-fg transition-colors font-mono text-sm uppercase tracking-widest"
        >
          View all posts →
        </a>
      </div>

      <!-- FeaturedPostsList: client:visible — below fold, hydrate on scroll -->
      <FeaturedPostsList posts={featuredPosts} client:visible />
    </div>
  </section>

  <!-- Categories: client:visible -->
  <CategoriesSection categories={HOMEPAGE_CATEGORIES} categoryCounts={categoryCounts} client:visible />

  <!-- Newsletter: client:visible -->
  <NewsletterSection
    endpoint={siteConfig.newsletter.endpoint}
    source={siteConfig.newsletter.source}
    client:visible
  />
</PageLayout>

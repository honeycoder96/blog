---
import PageLayout from '../layouts/PageLayout.astro';
import { HeroSection } from '../components/react/sections/HeroSection';
import { FeaturedPostsList } from '../components/react/blog/FeaturedPostsList';
import { CategoriesSection } from '../components/react/sections/CategoriesSection';
import { NewsletterSection } from '../components/react/sections/NewsletterSection';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = sorted.find((p) => p.data.featured);
const featuredPosts = sorted
  .filter((p) => p.data.featured)
  .map((p) => ({
    slug: p.slug,
    data: {
      title: p.data.title,
      date: p.data.date,
      category: p.data.category,
      author: p.data.author,
      summary: p.data.summary,
      readingTime: p.data.readingTime,
    },
  }));
---

<PageLayout title="blog.honeyhimself — Engineering Blog">
  <div class="px-8 lg:px-24">
    <div class="max-w-7xl mx-auto">
      <!-- Hero -->
      <HeroSection client:load />

      <!-- Featured post card -->
      {featuredPost && (
        <div class="mb-24">
          <p class="font-mono text-xs text-neutral-600 uppercase tracking-widest mb-6">
            Featured Post
          </p>
          <a
            href={`/blog/${featuredPost.slug}`}
            class="group block rounded-2xl bg-neutral-900/60 border border-neutral-800 p-8 md:p-10 hover:border-neutral-600 transition-colors duration-300"
          >
            <div class="flex flex-wrap items-center gap-4 mb-6 font-mono text-sm text-neutral-500">
              <span class="px-3 py-1 rounded-full border border-neutral-700 text-xs uppercase tracking-wider text-neutral-400">
                {featuredPost.data.category}
              </span>
              <span>{featuredPost.data.date}</span>
              {featuredPost.data.readingTime && (
                <span>· {featuredPost.data.readingTime} min read</span>
              )}
            </div>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-white leading-tight mb-5 group-hover:text-neutral-100 transition-colors max-w-3xl">
              {featuredPost.data.title}
            </h2>
            <p class="text-neutral-400 leading-relaxed max-w-2xl">
              {featuredPost.data.summary}
            </p>
            <div class="flex items-center gap-2 mt-8 font-mono text-sm font-bold uppercase tracking-widest text-white">
              Read Article
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </div>
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Featured writing section -->
  <section class="py-32 px-8 lg:px-24 border-t border-neutral-900 relative">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
          <h2 class="text-4xl font-display font-bold tracking-tight text-white mb-4">
            Featured Writing
          </h2>
          <p class="text-neutral-400 text-lg">
            Deep dives into patterns, performance, and engineering culture.
          </p>
        </div>
        <a
          href="/blog"
          class="magnetic flex items-center gap-2 text-white/80 hover:text-white pb-2 border-b border-white/20 hover:border-white transition-colors font-mono text-sm uppercase tracking-widest"
        >
          View all posts →
        </a>
      </div>

      <!-- FeaturedPostsList: client:visible — below fold, lazy hydrate -->
      <FeaturedPostsList posts={featuredPosts} client:load />
    </div>
  </section>

  <!-- Categories: client:visible -->
  <CategoriesSection client:visible />

  <!-- Newsletter: client:visible -->
  <NewsletterSection client:visible />
</PageLayout>

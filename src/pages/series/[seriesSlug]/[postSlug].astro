---
import { render } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import MdxImage from '../../../components/astro/MdxImage.astro';
import { splitSeriesEntries, resolveReadingTime } from '../../../lib/content';

export async function getStaticPaths() {
  const { indexEntries, postEntries } = await splitSeriesEntries();

  return indexEntries.flatMap(index => {
    const seriesSlug = index.slug.replace('/index', '');
    const postOrder: string[] = index.data.postOrder ?? [];

    return postOrder.flatMap((postSlug, i) => {
      const entry = postEntries.find(e => e.slug === `${seriesSlug}/${postSlug}`);
      if (!entry) return [];

      const prevSlug = postOrder[i - 1];
      const nextSlug = postOrder[i + 1];
      const prevEntry = prevSlug ? postEntries.find(e => e.slug === `${seriesSlug}/${prevSlug}`) : undefined;
      const nextEntry = nextSlug ? postEntries.find(e => e.slug === `${seriesSlug}/${nextSlug}`) : undefined;

      return [{
        params: { seriesSlug, postSlug },
        props: {
          entry,
          seriesTitle: index.data.title,
          part: i + 1,
          total: postOrder.length,
          prevPost: prevEntry
            ? { slug: prevSlug, title: prevEntry.data.title, href: `/series/${seriesSlug}/${prevSlug}` }
            : undefined,
          nextPost: nextEntry
            ? { slug: nextSlug, title: nextEntry.data.title, href: `/series/${seriesSlug}/${nextSlug}` }
            : undefined,
        },
      }];
    });
  });
}

const { entry, seriesTitle, part, total, prevPost, nextPost } = Astro.props;
const { seriesSlug } = Astro.params;
const { Content, headings } = await render(entry);

const readingTime = resolveReadingTime(entry.data.readingTime, entry.body);
---

<BlogLayout
  title={entry.data.title}
  description={entry.data.summary}
  date={entry.data.date ?? ''}
  pubDate={entry.data.pubDate}
  category={entry.data.category}
  author={entry.data.author}
  readingTime={readingTime}
  tags={entry.data.tags}
  headings={headings}
  prevPost={prevPost}
  nextPost={nextPost}
  seriesContext={{ seriesSlug, seriesTitle, part, total }}
  ogImage={`/og/series/${seriesSlug}/${Astro.params.postSlug}.png`}
>
  <Content components={{ img: MdxImage }} />
</BlogLayout>

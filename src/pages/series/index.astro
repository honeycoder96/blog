---
import PageLayout from '../../layouts/PageLayout.astro';
import { SeriesAccordion } from '../../components/react/series/SeriesAccordion';
import { AnimatedTitle } from '../../components/react/ui/AnimatedTitle';
import { buildFilterCategories } from '../../config/categories';
import { siteConfig } from '../../config/site';
import { parseSeriesCollection, countByCategory } from '../../lib/content';

const PAGE_SIZE = 5;

const allSeries = await parseSeriesCollection();

// Only the first page is baked into the HTML.
// Everything after that is fetched from /api/series/[category]/[page].json
const initialSeries = allSeries.slice(0, PAGE_SIZE);
const initialTotal = allSeries.length;
const categories = buildFilterCategories(allSeries.map((s) => s.category));
const categoryCounts = countByCategory(allSeries.map((s) => s.category));
const totalPosts = allSeries.reduce((sum, s) => sum + s.posts.length, 0);
---

<PageLayout
  title={`Series — ${siteConfig.author}`}
  description="In-depth reading tracks on JavaScript, architecture, and engineering — each a structured multi-part series."
>
  <div class="max-w-7xl mx-auto px-8 lg:px-24 py-16">
    <header class="mb-16">
      <AnimatedTitle
        text="Series"
        className="text-5xl md:text-7xl font-display font-bold tracking-tighter text-fg mb-6"
        client:visible
      />
      <p class="text-xl text-fg-muted max-w-2xl">
        {allSeries.length} {allSeries.length === 1 ? 'series' : 'series'}, {totalPosts} posts — structured multi-part reading tracks.
      </p>
    </header>

    <SeriesAccordion
      initialSeries={initialSeries}
      initialTotal={initialTotal}
      categories={categories}
      categoryCounts={categoryCounts}
      client:idle
    />
  </div>
</PageLayout>
